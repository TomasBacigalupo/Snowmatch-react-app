{
  "name": "SnowMatch",
  "author": "snowmatch.pro",
  "version": "9.0.0",
  "homepage": "https://snowmatch.pro",
  "description": "Javascript Version",
  "private": true,
  "scripts": {
    "start": "react-app-rewired start -f .env.dev",
    "capacitor": "react-app-rewired build -f .env.dev && npx cap sync",
    "build": "react-app-rewired build -f --max-old-space-size=5000 .env.production",
    "buildAndSnap": "react-app-rewired build -f --max-old-space-size=5000 .env.production && npx react-snap",
    "snap": "rm -f build/200.html build/404.html build/500.html && npx react-snap",
    "deploy-pi": "react-app-rewired --max-old-space-size=50000 build -f .env.production",
    "eject": "react-scripts eject",
    "lint": "eslint --ext .js,.jsx ./src",
    "lint:fix": "eslint --fix --ext .js,.jsx ./src",
    "clear-all": "rm -rf build node_modules",
    "re-start": "rm -rf build node_modules && yarn install && yarn start",
    "re-build": "rm -rf build node_modules && yarn install && yarn build"
  },
