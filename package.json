{
  "name": "SnowMatch",
  "author": "snowmatch.pro",
  "version": "10.0.0",
  "homepage": "https://snowmatch.pro",
  "description": "Javascript Version",
  "private": true,
  "scripts": {
    "start": "npx react-app-rewired start -f .env.dev",
    "build": "npx react-app-rewired build -f --max-old-space-size=5000 .env.production",
    "build:prerender": "npx react-app-rewired build -f --max-old-space-size=5000 .env.production && rm -f build/200.html build/404.html build/500.html && npx react-snap",
    "buildAndSnap": "npx react-app-rewired build -f --max-old-space-size=5000 .env.production && npx react-snap",
    "snap": "rm -f build/200.html build/404.html build/500.html && npx react-snap",
    "deploy-pi": "npx react-app-rewired --max-old-space-size=50000 build -f .env.production",
    "deploy": "./deploy-to-s3.sh",
    "deploy:upload-only": "./scripts/deploy-s3.sh",
    "eject": "react-scripts eject",
    "lint": "eslint --ext .js,.jsx ./src",
    "lint:fix": "eslint --fix --ext .js,.jsx ./src",
    "clear-all": "rm -rf build node_modules",
    "re-start": "rm -rf build node_modules && yarn install && yarn start",
    "re-build": "rm -rf build node_modules && yarn install && yarn build",
    "postinstall": "patch-package"
  },
  "reactSnap": {
    "source": "build",
    "destination": "build",
    "timeout": 120000,
    "waitUntil": "load",
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage",
      "--disable-accelerated-2d-canvas",
      "--disable-gpu"
    ],
    "include": [
      "/",
      "/es",
      "/en",
      "/pt",
      "/fr",
      "/en/all-teachers",
      "/es/all-teachers",
      "/pt/all-teachers",
      "/fr/all-teachers",
      "/all-teachers"
    ],
    "puppeteerExecutablePath": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
    "minifyHtml": {
      "collapseWhitespace": false,
      "removeComments": false
    },
    "puppeteerIgnoreHTTPSErrors": true,
    "preconnectThirdParty": false,
    "fixWebpackChunksIssue": false,
    "removeBlobs": true,
    "inlineCss": true,
    "skipFailedSnapshots": true
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "babel": {
    "presets": [
      "@babel/preset-react"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not safari < 10",
      "not chrome < 51",
      "not android < 5",
      "not ie < 12"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
